# ArcFlow Environment Configuration
# Copy to .env and fill in your values

# Server
PORT=3000

# Arc Network (defaults to testnet)
ARC_ENV=TESTNET

# Seller Configuration
SELLER_ADDRESS=0xYourSellerWalletAddress
SELLER_PRIVATE_KEY=0xYourSellerPrivateKey

# Webhook (optional)
WEBHOOK_URL=https://your-webhook-endpoint.com/arcflow

# Dashboard (optional)
DASHBOARD_PORT=4000
